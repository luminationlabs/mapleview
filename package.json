{
  "name": "cameraview",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "license": "AGPL-3.0-only",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:release": "expo run:ios --configuration Release",
    "ios:build": "eas build --platform ios --profile production",
    "ios:build:local": "PATH=/usr/bin:/bin:$PATH eas build --local --platform ios --profile production",
    "ios:build:adhoc": "eas build --platform ios --profile preview",
    "ios:submit": "eas submit --platform ios --profile production",
    "mac": "./scripts/run-mac.sh",
    "mac:release": "./scripts/build-mac-release.sh",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "vitest run",
    "bench": "vitest bench --run"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.3.1",
    "expo": "55.0.15",
    "expo-constants": "~55.0.14",
    "expo-dev-client": "~55.0.32",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-iap": "^4.2.7",
    "expo-image": "~55.0.8",
    "expo-keep-awake": "~55.0.6",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-screen-orientation": "~55.0.13",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "fast-xml-parser": "^5.5.12",
    "js-md5": "^0.8.3",
    "js-sha512": "^0.9.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "@types/ws": "^8.5.12",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4",
    "ws": "^8.20.1"
  },
  "private": true
}
