# Copy to .env.local and fill in the values below.

# Apple Developer Team ID (10 chars, e.g. ABCDE12345). Required for iOS /
# Mac Catalyst builds — found in App Store Connect or developer.apple.com
# under Membership Details. Used by plugins/with-mac-catalyst.js to set
# DEVELOPMENT_TEAM and derive the keychain access group.
#
# This file is loaded by Expo CLI (`expo run:ios`, `npx expo prebuild`) but
# NOT by EAS Build. For `eas build`, also set APPLE_TEAM_ID under each
# build profile's `env` block in eas.json (see eas.json.example).
APPLE_TEAM_ID=
